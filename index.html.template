            <button @click="saveLeadChanges()" x-show="isEditMode" class="bg-green-600 text-white py-2 px-4 rounded-lg">Save Changes</button>
            <button @click="cancelEditMode()" x-show="isEditMode" class="bg-red-600 text-white py-2 px-4 rounded-lg">Cancel</button>
