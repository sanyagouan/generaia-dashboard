        <div class="flex-grow">
            <template x-if="!isEditMode">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Status</label>
                        <span class="text-lg font-semibold" :style="{ color: getStatusColor(selectedLead.status) }" x-text="selectedLead.statusLabel"></span>
