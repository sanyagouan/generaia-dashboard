<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeneraIA CRM Dashboard</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Custom scrollbar for kanban */
        .kanban-scroll::-webkit-scrollbar {
            height: 8px;
        }
        .kanban-scroll::-webkit-scrollbar-track {
            background: #12121a;
        }
        .kanban-scroll::-webkit-scrollbar-thumb {
            background: #4a5568;
            border-radius: 4px;
        }
        .kanban-scroll::-webkit-scrollbar-thumb:hover {
            background: #6b7280;
        }
        /* Custom scrollbar for detail panel */
        .detail-panel-scroll::-webkit-scrollbar {
            width: 8px;
        }
        .detail-panel-scroll::-webkit-scrollbar-track {
            background: #12121a;
        }
        .detail-panel-scroll::-webkit-scrollbar-thumb {
            background: #4a5568;
            border-radius: 4px;
        }
        .detail-panel-scroll::-webkit-scrollbar-thumb:hover {
            background: #6b7280;
        }
    </style>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <!-- Sortable.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <!-- Alpine.js CDN -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-[#0a0a0f] text-[#e2e8f0] flex h-screen overflow-hidden" x-data="crmDashboard()">

    <!-- Sidebar -->
    <aside :class="{'w-24': !sidebarExpanded, 'w-64': sidebarExpanded}"
           class="bg-[#12121a] flex-shrink-0 border-r border-[#1e1e2e] p-4 flex flex-col transition-all duration-300">
        <div class="flex-shrink-0 mb-8">
            <template x-if="sidebarExpanded">
                <img src="https://placehold.co/120x40" alt="GeneraIA Logo" class="h-10 mx-auto">
            </template>
            <template x-if="!sidebarExpanded">
                <img src="https://placehold.co/40x40" alt="GeneraIA Logo" class="h-10 mx-auto">
            </template>
        </div>
        <nav class="flex-grow">
            <ul>
                <li class="mb-2">
                    <a href="#" @click="activeView = 'dashboard'"
                       :class="{'bg-[#f59e0b] text-[#0a0a0f]': activeView === 'dashboard', 'text-[#e2e8f0] hover:bg-[#1e1e2e]': activeView !== 'dashboard'}"
                       class="flex items-center p-3 rounded-lg transition-colors duration-200">
                        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        <span x-show="sidebarExpanded" class="ml-3">Dashboard</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="#" @click="activeView = 'leads'"
                       :class="{'bg-[#f59e0b] text-[#0a0a0f]': activeView === 'leads', 'text-[#e2e8f0] hover:bg-[#1e1e2e]': activeView !== 'leads'}"
                       class="flex items-center p-3 rounded-lg transition-colors duration-200">
                        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M12 20.354a4 4 0 010-5.292a4 4 0 010 5.292zM18 20.354a4 4 0 010-5.292M18 4.354a4 4 0 010 5.292a4 4 0 010-5.292zM6 4.354a4 4 0 010 5.292M6 20.354a4 4 0 010-5.292a4 4 0 010 5.292z"></path></svg>
                        <span x-show="sidebarExpanded" class="ml-3">Leads</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="#" @click="activeView = 'pipeline'"
                       :class="{'bg-[#f59e0b] text-[#0a0a0f]': activeView === 'pipeline', 'text-[#e2e8f0] hover:bg-[#1e1e2e]': activeView !== 'pipeline'}"
                       class="flex items-center p-3 rounded-lg transition-colors duration-200">
                        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 0h10a2 2 0 012 2v2a2 2 0 01-2 2h-4v2a2 2 0 01-2 2H9a2 2 0 01-2-2v-4a2 2 0 012-2h2a2 2 0 012 2h5"></path></svg>
                        <span x-show="sidebarExpanded" class="ml-3">Pipeline</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="#" @click="activeView = 'analytics'"
                       :class="{'bg-[#f59e0b] text-[#0a0a0f]': activeView === 'analytics', 'text-[#e2e8f0] hover:bg-[#1e1e2e]': activeView !== 'analytics'}"
                       class="flex items-center p-3 rounded-lg transition-colors duration-200">
                        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path></svg>
                        <span x-show="sidebarExpanded" class="ml-3">Analytics</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="#" @click="activeView = 'settings'"
                       :class="{'bg-[#f59e0b] text-[#0a0a0f]': activeView === 'settings', 'text-[#e2e8f0] hover:bg-[#1e1e2e]': activeView !== 'settings'}"
                       class="flex items-center p-3 rounded-lg transition-colors duration-200">
                        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.527.288 1.05.028 1.487-.208z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <span x-show="sidebarExpanded" class="ml-3">Configuración</span>
                    </a>
                </li>
            </ul>
        </nav>
        <div class="mt-auto pt-4 border-t border-[#1e1e2e] flex items-center justify-between" x-show="sidebarExpanded">
            <div class="flex items-center">
                <img src="https://placehold.co/40x40" alt="User Avatar" class="rounded-full mr-3">
                <span>User Name</span>
            </div>
            <button @click="sidebarExpanded = !sidebarExpanded"
                    class="p-2 rounded-full hover:bg-[#1e1e2e] text-[#e2e8f0]">
                <svg :class="{'rotate-180': sidebarExpanded}" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
            </button>
        </div>
        <div class="mt-auto pt-4 border-t border-[#1e1e2e] flex items-center justify-center" x-show="!sidebarExpanded">
             <button @click="sidebarExpanded = !sidebarExpanded"
                    class="p-2 rounded-full hover:bg-[#1e1e2e] text-[#e2e8f0]">
                <svg :class="{'rotate-180': sidebarExpanded}" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
            </button>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col p-4">
        <!-- Header -->
        <header class="flex items-center justify-between pb-4 border-b border-[#1e1e2e] mb-4">
            <h1 class="text-2xl font-bold" x-text="pageTitle"></h1>
            <div class="flex items-center space-x-4">
                <div class="relative">
                    <input type="text" placeholder="Search..."
                           class="bg-[#1e1e2e] text-[#e2e8f0] rounded-lg py-2 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-[#f59e0b]">
                    <svg class="w-5 h-5 text-[#9a9a9a] absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <button class="p-2 rounded-full hover:bg-[#1e1e2e] text-[#e2e8f0]">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                </button>
                <button class="bg-[#f59e0b] text-[#0a0a0f] py-2 px-4 rounded-lg flex items-center space-x-2">+ New Lead</button>
            </div>
        </header>

        <!-- Dynamic Content Area -->
        <main class="flex-grow overflow-y-auto detail-panel-scroll">
            <div x-show="activeView === 'dashboard'">
                <!-- Stats Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <template x-for="stat in stats" :key="stat.label">
                        <div class="bg-[#12121a] p-5 rounded-lg border border-[#1e1e2e] flex items-center justify-between">
                            <div>
                                <div class="text-sm text-[#9a9a9a]" x-text="stat.label"></div>
                                <div class="text-3xl font-bold text-[#e2e8f0]" x-text="stat.value"></div>
                            </div>
                            <div class="text-right">
                                <span :class="{'text-green-500': stat.trend === 'up', 'text-red-500': stat.trend === 'down'}"
                                      class="flex items-center text-sm font-semibold">
                                    <template x-if="stat.trend === 'up'">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414L10 3.586l4.707 4.707a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                                    </template>
                                    <template x-if="stat.trend === 'down'">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414L10 16.414l-4.707-4.707a1 1 0 011.414-1.414L9 12.586V5a1 1 0 112 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                    </template>
                                    <span x-text="stat.percentage"></span>%
                                </span>
                                <div class="text-xs text-[#9a9a9a]" x-text="stat.period"></div>
                            </div>
                        </div>
                    </template>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
                    <div class="bg-[#12121a] p-5 rounded-lg border border-[#1e1e2e]">
                        <h3 class="text-lg font-semibold mb-4">Leads Over Time</h3>
                        <canvas id="leadsLineChart"></canvas>
                    </div>
                    <div class="bg-[#12121a] p-5 rounded-lg border border-[#1e1e2e]">
                        <h3 class="text-lg font-semibold mb-4">Lead Status Distribution</h3>
                        <canvas id="statusDoughnutChart"></canvas>
                    </div>
                </div>

                <!-- Recent Activities (Placeholder) -->
                <div class="bg-[#12121a] p-5 rounded-lg border border-[#1e1e2e]">
                    <h3 class="text-lg font-semibold mb-4">Recent Activities</h3>
                    <ul class="space-y-2">
                        <li class="flex items-center space-x-2">
                            <span class="text-green-500">&#x2022;</span>
                            <span>New lead <span class="font-semibold">John Doe</span> added.</span>
                            <span class="text-xs text-[#9a9a9a]">2 hours ago</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-blue-500">&#x2022;</span>
                            <span>Lead <span class="font-semibold">Jane Smith</span> contacted.</span>
                            <span class="text-xs text-[#9a9a9a]">1 day ago</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-orange-500">&#x2022;</span>
                            <span>Trial scheduled for <span class="font-semibold">Peter Jones</span>.</span>
                            <span class="text-xs text-[#9a9a9a]">3 days ago</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div x-show="activeView === 'leads'">
                <h2 class="text-xl font-bold mb-4">All Leads</h2>
                <!-- Filters -->
                <div class="flex space-x-2 mb-4">
                    <template x-for="s in statusOptions" :key="s.value">
                        <button @click="filterStatus = (filterStatus === s.value ? '' : s.value)"
                                :class="{ 'bg-[#f59e0b] text-[#0a0a0f]': filterStatus === s.value, 'bg-[#1e1e2e] text-[#e2e8f0] hover:bg-[#1e1e2e]/70': filterStatus !== s.value }"
                                class="py-1 px-3 rounded-full text-sm">
                            <span x-text="s.label"></span> (<span x-text="filteredLeads.filter(lead => lead.status === s.value).length"></span>)
                        </button>
                    </template>
                     <button @click="exportCSV()" class="bg-green-600 text-white py-1 px-3 rounded-full text-sm hover:bg-green-700">
                        Export CSV
                    </button>
                </div>

                <!-- Table View -->
                <div class="bg-[#12121a] p-5 rounded-lg border border-[#1e1e2e] overflow-x-auto">
                    <table class="min-w-full divide-y divide-[#1e1e2e]">
                        <thead>
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-[#9a9a9a] uppercase tracking-wider"></th>
                                <template x-for="col in tableColumns" :key="col.key">
                                    <th class="px-6 py-3 text-left text-xs font-medium text-[#9a9a9a] uppercase tracking-wider cursor-pointer"
                                        @click="sortByColumn(col.key)">
                                        <div class="flex items-center">
                                            <span x-text="col.label"></span>
                                            <template x-if="sortColumn === col.key">
                                                <span x-html="sortDirection === 'asc' ? '&uarr;' : '&darr;'"></span>
                                            </template>
                                        </div>
                                    </th>
                                </template>
                                <th class="px-6 py-3 text-left text-xs font-medium text-[#9a9a9a] uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#1e1e2e]">
                            <template x-for="lead in paginatedLeads" :key="lead.id">
                                <tr class="hover:bg-[#1e1e2e] cursor-pointer" @click="openLeadDetail(lead)">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="w-3 h-3 rounded-full" :style="{ backgroundColor: getStatusColor(lead.status) }"></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.name"></td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.email"></td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.phone"></td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.statusLabel"></td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.course_interest"></td>
                                    <td class="px-6 py-4 whitespace-nowrap" x-text="lead.source"></td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <button @click.stop="editLead(lead)" class="text-[#f59e0b] hover:text-[#e2e8f0] mx-1">Edit</button>
                                        <button @click.stop="deleteLead(lead.id)" class="text-red-500 hover:text-red-400 mx-1">Delete</button>
                                    </td>
                                </tr>
                            </template>
                            <template x-if="paginatedLeads.length === 0">
                                <tr>
                                    <td colspan="8" class="text-center py-8 text-[#9a9a9a]">No leads found.</td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="flex justify-between items-center mt-4">
                    <span class="text-sm text-[#9a9a9a]">Showing <span x-text="firstLeadIndex"></span> to <span x-text="lastLeadIndex"></span> of <span x-text="filteredLeads.length"></span> leads</span>
                    <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                        <button @click="currentPage = Math.max(1, currentPage - 1)"
                                :disabled="currentPage === 1"
                                class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-[#1e1e2e] bg-[#12121a] text-sm font-medium text-[#e2e8f0] hover:bg-[#1e1e2e] disabled:opacity-50 disabled:cursor-not-allowed">
                            Previous
                        </button>
                        <template x-for="page in totalPages" :key="page">
                            <button @click="currentPage = page"
                                    aria-current="page"
                                    :class="{'z-10 bg-[#f59e0b] text-[#0a0a0f] border-[#f59e0b]': page === currentPage, 'bg-[#12121a] border-[#1e1e2e] text-[#e2e8f0] hover:bg-[#1e1e2e]': page !== currentPage}"
                                    class="relative inline-flex items-center px-4 py-2 border text-sm font-medium">
                                <span x-text="page"></span>
                            </button>
                        </template>
                        <button @click="currentPage = Math.min(totalPages, currentPage + 1)"
                                :disabled="currentPage === totalPages"
                                class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-[#1e1e2e] bg-[#12121a] text-sm font-medium text-[#e2e8f0] hover:bg-[#1e1e2e] disabled:opacity-50 disabled:cursor-not-allowed">
                            Next
                        </button>
                    </nav>
                </div>
            </div>

            <div x-show="activeView === 'pipeline'">
                <h2 class="text-xl font-bold mb-4">Sales Pipeline</h2>
                <!-- Kanban Board -->
                <div class="flex overflow-x-auto space-x-4 pb-4 kanban-scroll">
                    <template x-for="statusObj in statusOptions" :key="statusObj.value">
                        <div class="bg-[#12121a] rounded-lg border border-[#1e1e2e] flex-shrink-0 w-80">
                            <div class="h-2 rounded-t-lg" :style="{ backgroundColor: statusObj.color }"></div>
                            <h3 class="text-lg font-semibold px-4 py-3 border-b border-[#1e1e2e]" x-text="statusObj.label"></h3>
                            <div class="p-4 min-h-[200px]"
                                 :id="'kanban-col-' + statusObj.value"
                                 x-init="$nextTick(() => initializeSortable(statusObj.value))">
                                <template x-for="lead in leadsByStatus[statusObj.value]" :key="lead.id">
                                    <div class="bg-[#1e1e2e] p-4 mb-3 rounded-lg shadow-md border-l-4 cursor-grab active:cursor-grabbing"
                                         :style="{ borderColor: getStatusColor(lead.status) }"
                                         @click="openLeadDetail(lead)">
                                        <div class="flex items-center mb-2">
                                            <span class="w-3 h-3 rounded-full mr-2" :style="{ backgroundColor: getStatusColor(lead.status) }"></span>
                                            <span class="font-semibold" x-text="lead.name"></span>
                                        </div>
                                        <p class="text-sm text-[#9a9a9a]"><span x-text="lead.phone"></span> | <span x-text="lead.source"></span></p>
                                        <div class="flex justify-end mt-3 space-x-2">
                                            <button @click.stop="contactLead(lead.id)" class="text-[#f59e0b] hover:text-[#e2e8f0]">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-1.618A2 2 0 0015.382 17H9.236A2 2 0 017 14.382V12c0-.55.22-1.028.539-1.382l4.81-4.81a2 2 0 012.828 0l4.81 4.81c.319.354.539.832.539 1.382v2.382a2 2 0 01-2 2H5a2 2 0 01-2-2V5z"></path></svg>
                                            </button>
                                            <button @click.stop="editLead(lead)" class="text-[#f59e0b] hover:text-[#e2e8f0]">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                            </button>
                                        </div>
                                    </div>
                                </template>
                                <template x-if="leadsByStatus[statusObj.value].length === 0">
                                    <div class="text-center text-[#9a9a9a] py-8 border border-dashed border-[#1e1e2e] rounded-md">
                                        No leads in this stage.
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <div x-show="activeView === 'analytics'">
                <h2 class="text-xl font-bold mb-4">Analytics</h2>
                <p>Analytics content goes here.</p>
