                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Phone</label>
                        <p class="text-lg" x-text="selectedLead.phone"></p>
                    </div>
                     <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">WhatsApp ID</label>
                        <p class="text-lg" x-text="selectedLead.whatsapp_id"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Course Interest</label>
                        <p class="text-lg" x-text="selectedLead.course_interest"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9e9a]">Preferred Schedule</label>
                        <p class="text-lg" x-text="selectedLead.preferred_schedule"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Source</label>
                        <p class="text-lg" x-text="selectedLead.source"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Notes</label>
                        <p class="text-lg" x-text="selectedLead.notes || 'N/A'"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Created At</label>
                        <p class="text-lg" x-text="new Date(selectedLead.created_at).toLocaleString()"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-[#9a9a9a]">Updated At</label>
                        <p class="text-lg" x-text="new Date(selectedLead.updated_at).toLocaleString()"></p>
                    </div>
                </div>
            </template>
            <template x-if="isEditMode">
                <form class="space-y-4" @submit.prevent="saveLeadChanges()">
                    <div>
                        <label for="edit-name" class="block text-sm font-medium text-[#9a9a9a]">Name</label>
                        <input type="text" id="edit-name" x-model="editedLead.name"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                    <div>
                        <label for="edit-status" class="block text-sm font-medium text-[#9a9a9a]">Status</label>
                        <select id="edit-status" x-model="editedLead.status"
                                class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                            <template x-for="s in statusOptions" :key="s.value">
                                <option :value="s.value" x-text="s.label"></option>
                            </template>
                        </select>
                    </div>
                    <div>
                        <label for="edit-email" class="block text-sm font-medium text-[#9a9a9a]">Email</label>
                        <input type="email" id="edit-email" x-model="editedLead.email"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                    <div>
                        <label for="edit-phone" class="block text-sm font-medium text-[#9a9a9a]">Phone</label>
                        <input type="text" id="edit-phone" x-model="editedLead.phone"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                    <div>
                        <label for="edit-whatsapp" class="block text-sm font-medium text-[#9a9a9a]">WhatsApp ID</label>
                        <input type="text" id="edit-whatsapp" x-model="editedLead.whatsapp_id"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                    <div>
                        <label for="edit-course" class="block text-sm font-medium text-[#9a9a9a]">Course Interest</label>
                        <input type="text" id="edit-course" x-model="editedLead.course_interest"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                    <div>
                        <label for="edit-schedule" class="block text-sm font-medium text-[#9a9a9a]">Preferred Schedule</label>
                        <input type="text" id="edit-schedule" x-model="editedLead.preferred_schedule"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                     <div>
                        <label for="edit-source" class="block text-sm font-medium text-[#9a9a9a]">Source</label>
                         <input type="text" id="edit-source" x-model="editedLead.source"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]">
                    </div>
                     <div>
                        <label for="edit-notes" class="block text-sm font-medium text-[#9a9a9a]">Notes</label>
                         <textarea id="edit-notes" x-model="editedLead.notes" rows="3"
                               class="mt-1 block w-full bg-[#1e1e2e] border border-[#1e1e2e] rounded-md shadow-sm py-2 px-3 text-[#e2e8f0] focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b]"></textarea>
                    </div>
                </form>
            </template>

            <!-- Activity Timeline (Placeholder) -->
            <div class="mt-8 pt-6 border-t border-[#1e1e2e]">
                <h3 class="text-lg font-semibold mb-4">Activity Timeline</h3>
                <ul class="space-y-4">
                    <li class="relative pl-6">
                        <div class="absolute w-2 h-2 bg-[#f59e0b] rounded-full -left-1 top-1.5 ring-4 ring-[#12121a]"></div>
                        <p class="text-sm text-[#9a9a9a]">Sept 1, 2024</p>
                        <p>Lead created</p>
                    </li>
                    <li class="relative pl-6">
                        <div class="absolute w-2 h-2 bg-blue-500 rounded-full -left-1 top-1.5 ring-4 ring-[#12121a]"></div>
                        <p class="text-sm text-[#9a9a9a]">Sept 3, 2024</p>
                        <p>Contacted via email</p>
                    </li>
                </ul>
            </div>
        </div>
    </div>


    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('crmDashboard', () => ({
                sidebarExpanded: true,
                activeView: 'dashboard', // 'dashboard', 'leads', 'pipeline', 'analytics', 'settings'
                isDetailPanelOpen: false,
                selectedLead: {},
                isEditMode: false,
                editedLead: {},
                loadingLeads: true,
                leads: [],
                filterStatus: '',
                currentPage: 1,
                leadsPerPage: 10,
                sortColumn: 'name',
                sortDirection: 'asc', // 'asc' or 'desc'

                statusOptions: [
                    { value: 'new', label: 'Nuevo', color: '#f59e0b' },
                    { value: 'contacted', label: 'Contactado', color: '#3b82f6' }, // blue-500
                    { value: 'trial_scheduled', label: 'Trial Agendado', color: '#fbbf24' }, // amber-400
                    { value: 'trial_done', label: 'Trial Realizado', color: '#16a34a' }, // green-600
                    { value: 'enrolled', label: 'Inscrito', color: '#22c55e' }, // green-500
                    { value: 'lost', label: 'Perdido', color: '#ef4444' } // red-500
                ],
                
                tableColumns: [
                     { key: 'name', label: 'Name' },
                     { key: 'email', label: 'Email' },
                     { key: 'phone', label: 'Phone' },
                     { key: 'statusLabel', label: 'Status' },
                     { key: 'course_interest', label: 'Course' },
                     { key: 'source', label: 'Source' },
                ],

                async init() {
                    console.log("CRM Dashboard Alpine component initialized.");
                    this.pageTitle = this.getPageTitle();
                    await this.fetchLeads();
                    this.$watch('activeView', () => this.pageTitle = this.getPageTitle());
                    this.$watch('leads', () => {
                        this.initializeCharts();
                    });
                    this.initializeCharts(); // Initial chart setup
                },

                getPageTitle() {
                    switch (this.activeView) {
                        case 'dashboard': return 'Dashboard Overview';
                        case 'leads': return 'Leads Management';
                        case 'pipeline': return 'Sales Pipeline';
                        case 'analytics': return 'CRM Analytics';
                        case 'settings': return 'CRM Settings';
                        default: return 'GeneraIA CRM';
                    }
                },

                getStatusColor(status) {
                    const statusObj = this.statusOptions.find(s => s.value === status);
                    return statusObj ? statusObj.color : '#e2e8f0'; // Default text color
                },

                async fetchData(url, options = {}) {
                    const SUPABASE_ANON_KEY = '${SUPABASE_ANON_KEY}';
                    const headers = {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
                        'Content-Type': 'application/json',
                        ...options.headers
                    };
                    try {
                        const response = await fetch(url, { ...options, headers });
                        if (!response.ok) {
                            console.error('API Error:', response.status, response.statusText);
                            // Attempt to parse error as JSON, otherwise return response for status checking
                            try {
                                const errorData = await response.json();
                                console.error('Error details:', errorData);
                                throw new Error(JSON.stringify(errorData));
                            } catch (e) {
                                console.error('Could not parse error JSON, returning response:', response);
                                throw response; // Return the response object for non-JSON errors
                            }
                        }
                        const contentType = response.headers.get('content-type');
                        if (contentType && contentType.includes('application/json')) {
                            return await response.json();
                        } else {
                            return response; // Return response object for non-JSON success (e.g., 204 no content)
                        }
                    } catch (error) {
                        console.error('Fetch operation failed:', error);
                        throw error;
                    }
                },

                async fetchLeads() {
                    this.loadingLeads = true;
                    try {
                        const SUPABASE_URL = '/api'; // Fixed as per instructions
                        const response = await this.fetchData(`${SUPABASE_URL}/rest/v1/leads?select=*`);
                        if (response instanceof Response) { // Handle non-JSON response from fetchData
                            const text = await response.text();
                            console.error('Non-JSON response for leads:', text);
                            this.leads = [];
                        } else {
                             // Map status values to labels
                            this.leads = response.map(lead => ({
                                ...lead,
                                statusLabel: this.statusOptions.find(s => s.value === lead.status)?.label || lead.status,
                            }));
                        }
                    } catch (error) {
                        console.error("Failed to fetch leads:", error);
                        this.leads = []; // Ensure leads is an array even on error
                    } finally {
                        this.loadingLeads = false;
                    }
                },

                openLeadDetail(lead) {
                    this.selectedLead = { ...lead }; // Deep copy
                    this.editedLead = { ...lead };
                    this.isEditMode = false;
                    this.isDetailPanelOpen = true;
                },

                closeLeadDetail() {
                    this.isDetailPanelOpen = false;
                },

                startEditMode() {
                    this.editedLead = { ...this.selectedLead };
                    this.isEditMode = true;
                },

                async saveLeadChanges() {
                    try {
                        const SUPABASE_URL = '/api';
                        const updatedLead = { ...this.editedLead }; // Create a clean copy for sending
                        updatedLead.updated_at = new Date().toISOString(); // Update timestamp

                        const response = await this.fetchData(`${SUPABASE_URL}/rest/v1/leads?id=eq.${updatedLead.id}`, {
                            method: 'PATCH',
                            body: JSON.stringify(updatedLead)
                        });

                        if (response.status && response.status !== 204) {
                            throw new Error(`API returned status ${response.status}`);
                        }

                        // Update the local leads array
                        const index = this.leads.findIndex(l => l.id === updatedLead.id);
                        if (index !== -1) {
                            this.leads[index] = { ...this.leads[index], ...updatedLead, statusLabel: this.statusOptions.find(s => s.value === updatedLead.status)?.label || updatedLead.status };
                        }
                        this.selectedLead = { ...updatedLead };
                        this.isEditMode = false;
                        this.closeLeadDetail();
                        await this.fetchLeads(); // Re-fetch to ensure data consistency and chart updates
                        console.log('Lead updated successfully.');
                    } catch (error) {
                        console.error("Failed to update lead:", error);
                        alert('Failed to update lead. Check console for details.');
                    }
                },

                cancelEditMode() {
                    this.isEditMode = false;
                    this.editedLead = { ...this.selectedLead }; // Revert changes
                },

                async deleteLead(leadId) {
                    if (!confirm('Are you sure you want to delete this lead?')) {
                        return;
                    }
                    try {
                        const SUPABASE_URL = '/api';
                        const response = await this.fetchData(`${SUPABASE_URL}/rest/v1/leads?id=eq.${leadId}`, {
                            method: 'DELETE'
                        });

                        if (response.status && response.status !== 204) {
                             throw new Error(`API returned status ${response.status}`);
                        }

                        this.leads = this.leads.filter(lead => lead.id !== leadId);
                        this.closeLeadDetail();
                        console.log('Lead deleted successfully.');
                    } catch (error) {
                        console.error("Failed to delete lead:", error);
                        alert('Failed to delete lead. Check console for details.');
                    }
                },

                contactLead(leadId) {
                    alert(`Contacting lead ${leadId}`); // Placeholder for actual contact logic
                    // In a real app, this would trigger a modal, call, email, etc.
                },
                
                // Kanban board functionality
                initializeSortable(statusValue) {
                    const kanbanEl = document.getElementById('kanban-col-' + statusValue);
                    if (kanbanEl) {
                        Sortable.create(kanbanEl, {
                            group: 'leads',
                            animation: 150,
                            dataIdAttr: 'data-id',
                            onEnd: (evt) => {
                                const leadId = parseInt(evt.item.dataset.id);
                                const oldStatus = evt.from.id.replace('kanban-col-', '');
                                const newStatus = evt.to.id.replace('kanban-col-', '');

                                if (oldStatus !== newStatus) {
                                    this.updateLeadStatus(leadId, newStatus);
                                }
                            }
                        });
                    }
                },

                async updateLeadStatus(leadId, newStatus) {
                    try {
                        const SUPABASE_URL = '/api';
                        const leadToUpdate = this.leads.find(l => l.id === leadId);
                        if (!leadToUpdate) return;

                        const updatedLead = { ...leadToUpdate, status: newStatus, updated_at: new Date().toISOString() };
                        const response = await this.fetchData(`${SUPABASE_URL}/rest/v1/leads?id=eq.${leadId}`, {
                            method: 'PATCH',
                            body: JSON.stringify({ status: newStatus, updated_at: updatedLead.updated_at })
                        });

                        if (response.status && response.status !== 204) {
                             throw new Error(`API returned status ${response.status}`);
                        }

                        // Update local data
                        const index = this.leads.findIndex(l => l.id === leadId);
                        if (index !== -1) {
                            this.leads[index] = { ...this.leads[index], ...updatedLead, statusLabel: this.statusOptions.find(s => s.value === newStatus)?.label || newStatus };
                        }
                        await this.fetchLeads(); // Re-fetch to ensure data consistency and chart updates
                        console.log(`Lead ${leadId} status updated to ${newStatus}`);
                    } catch (error) {
                        console.error(`Failed to update lead ${leadId} status:`, error);
                        alert('Failed to update lead status. Check console for details.');
                        // Re-fetch to revert UI changes if API fails
                        await this.fetchLeads();
                    }
                },

                // Computed properties for dashboard stats
                get totalLeads() {
                    return this.leads.length;
                },
                get newLeadsCount() {
                    // Example: Leads created in the last 7 days
                    const sevenDaysAgo = new Date();
                    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
                    return this.leads.filter(lead => new Date(lead.created_at) > sevenDaysAgo && lead.status === 'new').length;
                },
                get enrolledLeadsCount() {
                    return this.leads.filter(lead => lead.status === 'enrolled').length;
                },
                get revenuePotential() {
                    // Placeholder: simple sum of a hypothetical 'value' field (not in current schema)
                    // For now, return a fixed value or calculate based on number of 'enrolled' leads
                    return this.enrolledLeadsCount * 1000; // Example: $1000 per enrolled lead
                },
                
                stats: [
                    { label: 'Total Leads', value: 0, percentage: '0', trend: 'up', period: 'Last 30 days' },
                    { label: 'New Leads', value: 0, percentage: '0', trend: 'up', period: 'Last 7 days' },
                    { label: 'Enrolled', value: 0, percentage: '0', trend: 'up', period: 'Total' },
                    { label: 'Revenue Potential', value: '$0', percentage: '0', trend: 'up', period: 'Active Pipeline' },
                ],

                // Initialize charts
                lineChart: null,
                doughnutChart: null,

                initializeCharts() {
                    // Destroy existing charts to prevent duplicates
                    if (this.lineChart) this.lineChart.destroy();
                    if (this.doughnutChart) this.doughnutChart.destroy();

                    // Line Chart for Leads Over Time
                    const createdDates = this.leads.map(lead => new Date(lead.created_at).toLocaleDateString());
                    const uniqueDates = [...new Set(createdDates)].sort((a, b) => new Date(a) - new Date(b));
                    const leadsByDate = uniqueDates.map(date => createdDates.filter(d => d === date).length);

                    const lineCtx = document.getElementById('leadsLineChart');
                    if (lineCtx) {
                        this.lineChart = new Chart(lineCtx, {
                            type: 'line',
                            data: {
                                labels: uniqueDates,
                                datasets: [{
                                    label: 'New Leads',
                                    data: leadsByDate,
                                    borderColor: '#f59e0b',
                                    backgroundColor: 'rgba(245, 158, 11, 0.2)',
                                    fill: true,
                                    tension: 0.3
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { labels: { color: '#e2e8f0' } }
                                },
                                scales: {
                                    x: {
                                        ticks: { color: '#9a9a9a' },
                                        grid: { color: '#1e1e2e' }
                                    },
                                    y: {
                                        ticks: { color: '#9a9a9a' },
                                        grid: { color: '#1e1e2e' },
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                    }

                    // Doughnut Chart for Lead Status Distribution
                    const statusCounts = {};
                    this.statusOptions.forEach(s => statusCounts[s.label] = 0); // Initialize all labels to 0
                    this.leads.forEach(lead => {
                        const statusLabel = this.statusOptions.find(s => s.value === lead.status)?.label;
                        if (statusLabel) {
                            statusCounts[statusLabel] = (statusCounts[statusLabel] || 0) + 1;
                        }
                    });

                    const doughnutCtx = document.getElementById('statusDoughnutChart');
                    if (doughnutCtx) {
                        this.doughnutChart = new Chart(doughnutCtx, {
                            type: 'doughnut',
                            data: {
                                labels: Object.keys(statusCounts),
                                datasets: [{
                                    data: Object.values(statusCounts),
                                    backgroundColor: this.statusOptions.map(s => s.color),
                                    hoverOffset: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'right',
                                        labels: { color: '#e2e8f0' }
                                    }
                                }
                            }
                        });
                    }

                    // Update stats (re-calculate on leads change)
                    this.stats[0].value = this.totalLeads;
                    this.stats[0].percentage = ((Math.random() * (15 - 5) + 5).toFixed(1)); // Example random trend
                    this.stats[0].trend = Math.random() > 0.5 ? 'up' : 'down';

                    this.stats[1].value = this.newLeadsCount;
                    this.stats[1].percentage = ((Math.random() * (20 - 10) + 10).toFixed(1)); // Example random trend
                    this.stats[1].trend = Math.random() > 0.5 ? 'up' : 'down';

                    this.stats[2].value = this.enrolledLeadsCount;
                    this.stats[2].percentage = ((Math.random() * (10 - 2) + 2).toFixed(1)); // Example random trend
                    this.stats[2].trend = Math.random() > 0.5 ? 'up' : 'down';

                    this.stats[3].value = `$${this.revenuePotential.toLocaleString()}`;
                    this.stats[3].percentage = ((Math.random() * (30 - 15) + 15).toFixed(1)); // Example random trend
                    this.stats[3].trend = Math.random() > 0.5 ? 'up' : 'down';
                },

                // Leads table view pagination and sorting
                get filteredLeads() {
                    let filtered = this.leads;
                    if (this.filterStatus) {
                        filtered = filtered.filter(lead => lead.status === this.filterStatus);
                    }
                    return filtered;
                },

                get sortedLeads() {
                    return [...this.filteredLeads].sort((a, b) => {
                        const aValue = a[this.sortColumn];
                        const bValue = b[this.sortColumn];

                        if (aValue < bValue) return this.sortDirection === 'asc' ? -1 : 1;
                        if (aValue > bValue) return this.sortDirection === 'asc' ? 1 : -1;
                        return 0;
                    });
                },

                sortByColumn(column) {
                    if (this.sortColumn === column) {
                        this.sortDirection = this.sortDirection === 'asc' ? 'desc' : 'asc';
                    } else {
                        this.sortColumn = column;
                        this.sortDirection = 'asc';
                    }
                },

                get paginatedLeads() {
                    const start = (this.currentPage - 1) * this.leadsPerPage;
                    const end = start + this.leadsPerPage;
                    return this.sortedLeads.slice(start, end);
                },

                get totalPages() {
                    return Math.ceil(this.filteredLeads.length / this.leadsPerPage);
                },

                get firstLeadIndex() {
                    return (this.currentPage - 1) * this.leadsPerPage + 1;
                },

                get lastLeadIndex() {
                    return Math.min(this.currentPage * this.leadsPerPage, this.filteredLeads.length);
                },

                // Kanban leads by status
                get leadsByStatus() {
                    const grouped = {};
                    this.statusOptions.forEach(status => {
                        grouped[status.value] = this.leads.filter(lead => lead.status === status.value);
                    });
                    return grouped;
                },

                exportCSV() {
                    if (this.leads.length === 0) {
                        alert('No leads to export.');
                        return;
                    }

                    const headers = [
                        'id', 'name', 'phone', 'email', 'course_interest',
                        'preferred_schedule', 'source', 'status', 'whatsapp_id', 'notes',
                        'created_at', 'updated_at'
                    ];
                    const csvRows = [];
                    csvRows.push(headers.join(',')); // Add header row

                    this.leads.forEach(lead => {
                        const values = headers.map(header => {
                            let value = lead[header] !== undefined && lead[header] !== null ? String(lead[header]) : '';
                            // Escape double quotes by doubling them, and enclose entire field in quotes if it contains comma or double quote
                            value = value.replace(/"/g, '""');
                            if (value.includes(',') || value.includes('"') || value.includes(String.fromCharCode(10))) {
                                value = `"${value}"`;
                            }
                            return value;
                        });
                        csvRows.push(values.join(','));
                    });

                    const csvString = csvRows.join(String.fromCharCode(10)); // Use String.fromCharCode(10) for newline

                    const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
                    const link = document.createElement('a');
                    link.href = URL.createObjectURL(blob);
                    link.setAttribute('download', 'generaia_leads.csv');
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }
            }));
        });
    </script>
</body>
</html>